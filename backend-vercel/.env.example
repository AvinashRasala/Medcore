# ----- Database -----
# CRITICAL FOR SERVERLESS: use Supabase's CONNECTION POOLER URL (port 6543,
# pgbouncer mode), NOT the direct connection (port 5432). Serverless
# functions open many short-lived connections; without pooling you will
# exhaust Supabase's connection limit under real traffic.
#
# Get this from Supabase dashboard -> Connect -> "Transaction pooler"
# Format: postgresql://postgres.PROJECT_REF:[PASSWORD]@aws-x-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ----- Auth -----
JWT_SECRET="replace-this-with-a-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# ----- CORS -----
# Set this to your deployed Vercel frontend URL once you have it,
# e.g. https://medcore-frontend.vercel.app
# Using "*" works for testing but isn't recommended for production.
CORS_ORIGIN="*"

# ----- Email (Resend) -----
# Get a free API key at https://resend.com (3,000 emails/month free)
RESEND_API_KEY="re_your_api_key_here"
# Without your own verified domain in Resend, you can only send TO the
# email address you signed up to Resend with.
RESEND_FROM_EMAIL="MedCore <onboarding@resend.dev>"
# Your deployed frontend URL — used to build the verification link
FRONTEND_URL="https://medcore-frontend.vercel.app"

# ----- Environment -----
NODE_ENV=production
