# ----- Database -----
# Production / real usage: PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Free hosted Postgres options: Supabase, Railway, Neon, Render
DATABASE_URL="postgresql://postgres:password@localhost:5432/hospital_db"

# ----- Auth -----
JWT_SECRET="replace-this-with-a-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# ----- Server -----
PORT=5000
NODE_ENV=development

# ----- CORS -----
# The URL your frontend runs on (Vite default shown)
CORS_ORIGIN="http://localhost:5173"

# ----- Email (Resend) -----
# Get a free API key at https://resend.com (3,000 emails/month free)
RESEND_API_KEY="re_your_api_key_here"
# Without your own verified domain in Resend, you can only send TO the
# email address you signed up to Resend with. Leave this default until
# you verify a real domain.
RESEND_FROM_EMAIL="MedCore <onboarding@resend.dev>"
# Used to build the verification link sent in the email
FRONTEND_URL="http://localhost:5173"
