# URL of the backend API
VITE_API_URL=http://localhost:5000/api

# Which backend style to call: "express" (default, for local dev against
# the backend/ folder) or "vercel" (for the deployed backend-vercel/ API,
# which consolidates routes and uses ?id=/?action= query params instead
# of path segments, to stay under Vercel's serverless function limit).
VITE_DEPLOYMENT_TARGET=express
